# ─────────────────────────────────────────────────────────────────────────────
# RutAIGeoProxi — Plantilla de variables de entorno
# Copia este archivo como ".env" y rellena los valores reales.
# NUNCA commitees el archivo .env real al repositorio.
# ─────────────────────────────────────────────────────────────────────────────

# ── Base de Datos ──────────────────────────────────────────────────────────
# SQLite (desarrollo local)
DATABASE_URL=sqlite:///./rutaigeoproxi.db
# PostgreSQL (producción — Render te da esta URL automáticamente)
# DATABASE_URL=postgresql://usuario:contraseña@host:5432/rutaigeoproxi_db

# ── JWT ────────────────────────────────────────────────────────────────────
# Genera una llave segura con:  python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=REEMPLAZA_CON_TOKEN_HEX_32_CARACTERES
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=120

# ── Admin Seed ─────────────────────────────────────────────────────────────
# Usuario administrador creado automáticamente al levantar el servidor.
ADMIN_EMAIL=admin@rutaigeoproxi.com
ADMIN_PASSWORD=CambiaMeAhora2026!

# ── Debug (SOLO DESARROLLO — NO USAR EN PRODUCCIÓN) ───────────────────────
DEBUG_RESET_TOKEN=false

# ── CORS ───────────────────────────────────────────────────────────────────
# En producción, agrega la URL de tu frontend en Render
CORS_ORIGINS=http://localhost:4200,https://tu-frontend.onrender.com

# ── Firebase Storage (opcional) ────────────────────────────────────────────
# Dejar vacío para usar almacenamiento local en backend/uploads/
FIREBASE_CREDENTIALS_PATH=
FIREBASE_STORAGE_BUCKET=

# ── IA — Clasificación de Incidentes (APIs Externas) ──────────────────────
# Groq: https://console.groq.com → API Keys
GROQ_API_KEY=gsk_TU_API_KEY_DE_GROQ
# Roboflow: https://app.roboflow.com → Settings → API
ROBOFLOW_API_KEY=TU_API_KEY_DE_ROBOFLOW
ROBOFLOW_MODEL=rutai-vision-pro
ROBOFLOW_VERSION=2

# ── SMTP (Brevo) ───────────────────────────────────────────────────────────
SMTP_SERVER=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=TU_EMAIL_SMTP_BREVO
SMTP_PASSWORD=TU_API_KEY_BREVO
FROM_EMAIL=no-reply@rutaigeoproxi.com